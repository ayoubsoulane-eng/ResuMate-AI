# ResuMate AI - Backend Configuration
# Copy this file to .env and fill in your values.
# The app runs in mock/development mode without any keys.

# Server port (default: 3001)
PORT=3001

# ---- REQUIRED for Auth ----
# Generate a strong random string: openssl rand -base64 32
JWT_SECRET=change-this-to-a-random-secret-in-production

# ---- Optional: AI Resume Generation ----
# Get your key at https://platform.openai.com/api-keys
# Without this key, resumes use template-based fallback generation.
OPENAI_API_KEY=

# ---- Optional: Stripe Payments ----
# Get keys at https://dashboard.stripe.com/test/apikeys
# Without these keys, payments run in mock mode (auto-creates subscriptions).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Frontend URL for CORS and payment redirects
FRONTEND_URL=http://localhost:5173